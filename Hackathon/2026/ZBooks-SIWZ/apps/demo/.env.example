# Required: secret used to sign NextAuth JWTs and SIWZ nonce tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# Required: the canonical URL of this app. Used by NextAuth for redirects.
NEXTAUTH_URL=http://localhost:3000

# The domain that will appear in the SIWZ challenge ("Sign in with your
# Zcash account: <addr>"). Must match what the browser sees.
SIWZ_DOMAIN=localhost:3000

# Network the demo runs on. Demo accepts only addresses on this network.
# One of: mainnet | testnet | regtest
SIWZ_NETWORK=mainnet

# Same value as SIWZ_NETWORK, but exposed to the browser bundle so the
# <SignInWithZcash /> component can validate addresses client-side.
NEXT_PUBLIC_SIWZ_NETWORK=mainnet

# Service address for the SIWZ memo-challenge flow. Users send a tiny ZEC
# amount here to authenticate. Must be a TRANSPARENT address on the same
# network as SIWZ_NETWORK so the public block explorer can verify the
# transparent output.
#
# ⚠️  YOU MUST CONTROL THE SPENDING KEY OF THIS ADDRESS. Funds sent here
# by sign-in flows belong to YOU; lose the spending key and the funds are
# unrecoverable.
#
# ⚠️  DO NOT use any address whose private key is in this repo or another
# public source — anyone who reads the source can sweep funds.
#
# Generate one safely with:
#   node scripts/gen-service-address.mjs
# (saves the WIF to ./.service-address.local.txt — gitignored)
#
# Or paste an address from your own existing wallet.
SIWZ_SERVICE_ADDRESS=

# Optional: Blockchair API key for higher rate limits. Free tier works
# for low-volume hackathon demos without a key.
# BLOCKCHAIR_API_KEY=

# Optional: set to "1" to bypass real block explorer lookups and use the
# in-memory MockExplorer. Useful when demoing without spending ZEC.
# SIWZ_DEMO=1

# Bearer token gating /api/cron/sync-keys. Required if you want the books to
# stay current when nobody is signed in. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
# Set it as a Vercel project env var, then point any external scheduler at
# the endpoint with header "Authorization: Bearer <CRON_SECRET>":
#   - cron-job.org (free, 1min granularity, what this repo's setup uses)
#   - UptimeRobot, GitHub Actions cron, plain server crontab
#
# Vercel Hobby caps cron jobs at one run per day; an external scheduler
# bypasses that and is the recommended path. Pro accounts can also add a
# "crons" array to vercel.json and skip the external scheduler entirely.
#
# When unset, the route returns 500 and the in-tab BackgroundSync still
# covers the case where an admin/treasurer is browsing.
# CRON_SECRET=

# ─── Shielded sign-in (sapling / unified service address) ────────────
#
# When SIWZ_SERVICE_ADDRESS is a zs… or u1… address, ZBooks needs a
# Zcash daemon to decrypt incoming memos (public block explorers can't —
# they don't have the IVK). Configure one of the two transports below.
#
# Option A: HTTP JSON-RPC (production-shaped, works across machines)
#   ZCASH_RPC_URL=http://127.0.0.1:8232
#   ZCASH_RPC_USER=...
#   ZCASH_RPC_PASS=...
#   # or, for cookie auth (read from ~/.zcash/.cookie, format "__cookie__:HEX"):
#   # ZCASH_RPC_COOKIE=__cookie__:abcd1234...
#
# Option B: zcash-cli shell-out (local dev, same machine as the daemon)
#   ZCASH_CLI_PATH=/usr/local/bin/zcash-cli
#
# Either path uses the standard `z_listreceivedbyaddress` RPC to get
# decrypted memos for incoming notes at SIWZ_SERVICE_ADDRESS. The daemon
# must have the IVK for that address (i.e. you generated it there, OR
# imported the IVK via z_importviewingkey).

# Optional: Discord webhook URL. When set, ZBooks pings this channel when a
# payout run needs approvals and when an approval is recorded. Treasurers
# can react in chat instead of refreshing the page. Configure under your
# Discord server: Server Settings → Integrations → Webhooks → New Webhook.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
