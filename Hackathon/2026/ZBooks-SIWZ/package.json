{
  "name": "siwz-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Sign in with Zcash — drop-in authentication for the open web",
  "packageManager": "pnpm@9.9.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "build:all": "pnpm -r run build",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "dev:zbooks": "pnpm --filter @zbooks/app dev",
    "dev:demo": "pnpm --filter @zbooks/app dev",
    "dev:docs": "pnpm --filter @siwz/docs dev",
    "clean": "pnpm -r exec rm -rf dist .next node_modules",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsup": "^8.2.4",
    "vitest": "^2.0.5",
    "@types/node": "^20.14.10"
  },
  "keywords": [
    "zcash",
    "authentication",
    "siwz",
    "sign-in",
    "web3",
    "privacy"
  ],
  "license": "MIT"
}
