# z3 compose configuration (mirrors ZcashFoundation/z3 .env.example).
# Copy to .env and edit, or let z3launcher generate the environment for you.

# Network: Mainnet (default), Testnet, or Regtest.
# NOTE: Testnet also requires network = "test" in config/zallet.toml, and
# Regtest uses a separate overlay (.env.regtest). See plan §3.
NETWORK_NAME=Mainnet

# Host directory bind-mounted into Zebra's cache (/home/zebra/.cache/zebra).
# Fast-start: point this at a pre-synced snapshot's cache root to skip the
# 1-3 day cold sync. State lives at <dir>/state/v<N>/<network>.
Z3_ZEBRA_CACHE_DIR=./data/zebra

# Host port mappings (bound to 127.0.0.1 by the compose file).
Z3_ZEBRA_HOST_RPC_PORT=18232
Z3_ZEBRA_HOST_HEALTH_PORT=8080
ZAINO_HOST_GRPC_PORT=8137
ZAINO_HOST_JSONRPC_PORT=8237
ZALLET_HOST_RPC_PORT=28232

# Pinned images (override to upgrade; verify tags against the upstream z3 repo
# and Docker Hub). Zebra's upstream z3 default is :latest — pinned here.
ZEBRA_IMAGE=zfnd/zebra:5.2.0
ZAINO_IMAGE=zingodevops/zainod:0.4.1
ZALLET_IMAGE=zodlinc/zallet:v0.1.0-alpha.4
ZCASHD_IMAGE=zodlinc/zcashd:v6.12.1
